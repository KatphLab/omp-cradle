{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oh-my-pi.local/schemas/omp-swarm-dag.schema.json",
  "title": "OMP Swarm DAG",
  "description": "YAML schema for omp-swarm DAG files consumed by src/swarm/swarm/schema.ts.",
  "type": "object",
  "additionalProperties": false,
  "required": ["swarm"],
  "properties": {
    "swarm": { "$ref": "#/$defs/swarmConfig" }
  },
  "$defs": {
    "swarmConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "workspace", "concurrency", "nodes"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[\\w.-]+$",
          "description": "Swarm name used for state directory naming."
        },
        "workspace": {
          "type": "string",
          "minLength": 1,
          "description": "Workspace directory. Relative paths resolve from the YAML file location."
        },
        "mode": {
          "type": "string",
          "enum": ["pipeline", "parallel", "sequential"],
          "default": "sequential"
        },
        "target_count": {
          "type": "integer",
          "minimum": 1,
          "default": 1,
          "description": "Number of full-DAG iterations. Only valid with mode: pipeline."
        },
        "concurrency": {
          "type": "integer",
          "minimum": 1,
          "description": "Maximum number of agent nodes that may run at once across this DAG and any subgraphs. Bash nodes do not count toward this limit."
        },
        "model": { "$ref": "#/$defs/model" },
        "model_routing": { "$ref": "#/$defs/modelRoutingPolicy" },
        "restart_policy": { "$ref": "#/$defs/restartPolicy" },
        "nodes": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "$ref": "#/$defs/node" }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "mode": { "not": { "const": "pipeline" } }
            },
            "required": ["target_count"]
          },
          "then": {
            "properties": {
              "target_count": { "const": 1 }
            }
          }
        }
      ]
    },
    "model": {
      "type": "string",
      "minLength": 1,
      "description": "Optional model selector forwarded to the subagent executor, for example pi/smol, pi/slow, or provider/model-id."
    },
    "modelUsageEstimate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "input_tokens",
        "output_tokens",
        "cache_read_tokens",
        "cache_write_tokens"
      ],
      "properties": {
        "input_tokens": { "type": "integer", "minimum": 0 },
        "output_tokens": { "type": "integer", "minimum": 0 },
        "cache_read_tokens": { "type": "integer", "minimum": 0 },
        "cache_write_tokens": { "type": "integer", "minimum": 0 }
      },
      "anyOf": [
        { "properties": { "input_tokens": { "minimum": 1 } } },
        { "properties": { "output_tokens": { "minimum": 1 } } },
        { "properties": { "cache_read_tokens": { "minimum": 1 } } },
        { "properties": { "cache_write_tokens": { "minimum": 1 } } }
      ]
    },
    "modelRoutingPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "allowed_aliases",
        "minimum_quality",
        "max_estimated_cost_usd",
        "allow_zero_marginal_cost",
        "default_usage"
      ],
      "properties": {
        "enabled": { "const": true },
        "allowed_aliases": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^pi/[a-z][a-z0-9-]*$",
            "description": "Base built-in OMP role alias. Runtime offline validation checks against OMP's MODEL_ROLE_IDS."
          }
        },
        "minimum_quality": {
          "type": "string",
          "enum": ["economy", "standard", "premium"]
        },
        "max_estimated_cost_usd": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "allow_zero_marginal_cost": { "type": "boolean" },
        "default_usage": { "$ref": "#/$defs/modelUsageEstimate" }
      }
    },
    "agentWorkload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile"],
      "properties": {
        "profile": {
          "type": "string",
          "enum": [
            "general",
            "implementation",
            "planning",
            "review",
            "design",
            "vision"
          ]
        },
        "estimated_usage": { "$ref": "#/$defs/modelUsageEstimate" }
      }
    },
    "nodeNameList": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "default": [],
      "description": "List of local typed node ids. The runtime validates that each name exists and is not self-referential."
    },
    "restartPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_restarts",
        "max_restarts_per_target",
        "max_node_attempts"
      ],
      "properties": {
        "max_restarts": { "type": "integer", "minimum": 1 },
        "max_restarts_per_target": { "type": "integer", "minimum": 1 },
        "max_node_attempts": { "type": "integer", "minimum": 1 }
      }
    },
    "nodeControl": {
      "type": "object",
      "additionalProperties": false,
      "required": ["signal", "allowed_restart_targets"],
      "properties": {
        "signal": { "type": "string", "minLength": 1 },
        "allowed_restart_targets": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "node": {
      "oneOf": [
        { "$ref": "#/$defs/agentNode" },
        { "$ref": "#/$defs/bashNode" },
        { "$ref": "#/$defs/graphNode" }
      ]
    },
    "agentNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "role", "task"],
      "properties": {
        "type": { "const": "agent" },
        "role": {
          "type": "string",
          "minLength": 1
        },
        "task": {
          "type": "string",
          "minLength": 1
        },
        "extra_context": {
          "type": "string"
        },
        "waits_for": { "$ref": "#/$defs/nodeNameList" },
        "reports_to": { "$ref": "#/$defs/nodeNameList" },
        "model": { "$ref": "#/$defs/model" },
        "workload": { "$ref": "#/$defs/agentWorkload" },
        "tools": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^\\S(?:[\\s\\S]*\\S)?$"
          }
        },
        "control": { "$ref": "#/$defs/nodeControl" }
      }
    },
    "bashNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "command", "output_path"],
      "properties": {
        "type": { "const": "bash" },
        "command": { "type": "string", "minLength": 1 },
        "output_path": { "type": "string", "minLength": 1 },
        "cwd": { "type": "string", "minLength": 1 },
        "waits_for": { "$ref": "#/$defs/nodeNameList" },
        "reports_to": { "$ref": "#/$defs/nodeNameList" }
      }
    },
    "graphNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "const": "graph" },
        "path": {
          "type": "string",
          "minLength": 1,
          "pattern": "^\\S(?:[\\s\\S]*\\S)?$",
          "description": "Graph YAML path. Relative paths resolve from the YAML file that declares this graph."
        },
        "swarm": { "$ref": "#/$defs/swarmConfig" },
        "waits_for": { "$ref": "#/$defs/nodeNameList" },
        "reports_to": { "$ref": "#/$defs/nodeNameList" },
        "repeat": { "$ref": "#/$defs/graphRepeat" },
        "control": { "$ref": "#/$defs/nodeControl" }
      },
      "oneOf": [{ "required": ["path"] }, { "required": ["swarm"] }]
    },
    "graphRepeat": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_rounds",
        "stop_signal",
        "success_value",
        "continue_value"
      ],
      "properties": {
        "max_rounds": { "type": "integer", "minimum": 1 },
        "stop_signal": { "type": "string", "minLength": 1 },
        "success_value": { "type": "string", "minLength": 1 },
        "continue_value": { "type": "string", "minLength": 1 }
      }
    }
  }
}
