{
  "name": "omp-cradle",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0 <25"
  },
  "scripts": {
    "lint": "eslint . --cache",
    "lint:fix": "eslint . --fix --cache",
    "typecheck": "tsgo --noEmit",
    "format": "prettier . --log-level silent --write",
    "prepare": "husky",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "depcruise": "depcruise src",
    "dupcheck": "jscpd src",
    "check": "bun format && bun lint && bun typecheck && bun depcruise && bun knip && bun dupcheck",
    "fix": "bun format && bun lint:fix && bun knip:fix"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^25.6.0",
    "dependency-cruiser": "^17.4.0",
    "eslint": "^9",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "jscpd": "^4.0.9",
    "knip": "^6.4.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "prettier-plugin-organize-imports": "^4.3.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  },
  "peerDependencies": {
    "@oh-my-pi/pi-ai": "*",
    "@oh-my-pi/pi-catalog": "*",
    "@oh-my-pi/pi-coding-agent": "*"
  },
  "omp": {
    "extensions": [
      "./src/commit-command/index.ts",
      "./src/council/index.ts",
      "./src/hide-builtins/index.ts",
      "./src/swarm/index.ts",
      "./src/system-prompt/index.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "packageManager": "bun@1.3.14",
  "dependencies": {
    "@typescript/native-preview": "^7.0.0-dev.20260704.1"
  },
  "bin": {
    "omp-swarm": "src/swarm/cli.ts"
  }
}
